# =============================================================================
# Binding With Books PR — Environment Variables
# Copy this to .env for local dev with netlify dev, or set in Netlify dashboard
# =============================================================================

# Admin password SHA-256 hash.
# Default (admin123): 240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9
# Generate your own: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
ADMIN_PASSWORD_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9

# Secret used to sign admin session tokens (use a long random string in production!)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production
